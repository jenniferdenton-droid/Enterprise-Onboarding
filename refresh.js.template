// ────────────────────────────────────────────────────────────────────────────
// PHASE 2 STARTER — /api/refresh
// Rename this file to `refresh.js` (drop the `.template`) when ready to wire live.
// Path:  api/refresh.js   (Vercel will auto-route it as /api/refresh)
// ────────────────────────────────────────────────────────────────────────────
//
// Required Vercel env vars (Project Settings → Environment Variables):
//   ANTHROPIC_API_KEY        — Anthropic API key (server-side, never exposed)
//   HUBSPOT_MCP_URL          — https://mcp.hubspot.com/anthropic   (or your tenant URL)
//   SLACK_MCP_URL            — Slack MCP server URL (Salesforce-hosted Slack MCP)
//   DASHBOARD_PASSWORD       — Optional: simple shared-secret to gate this endpoint
//
// Architecture:
//   Browser → /api/refresh (this file) → Anthropic API w/ HubSpot + Slack MCPs
//   Returns: { companies: [...], notes: { "rivkin": [...], "haven": [...], ... } }
//
// ────────────────────────────────────────────────────────────────────────────

export default async function handler(req, res) {
  // 1. Optional auth gate
  if (process.env.DASHBOARD_PASSWORD) {
    const auth = req.headers["x-dashboard-key"];
    if (auth !== process.env.DASHBOARD_PASSWORD) {
      return res.status(401).json({ error: "unauthorized" });
    }
  }

  const KEY = process.env.ANTHROPIC_API_KEY;
  const HUBSPOT_MCP = process.env.HUBSPOT_MCP_URL || "https://mcp.hubspot.com/anthropic";
  const SLACK_MCP = process.env.SLACK_MCP_URL;

  if (!KEY) return res.status(500).json({ error: "ANTHROPIC_API_KEY not set" });

  try {
    // ── STEP 1: Pull enterprise companies + deals from HubSpot ──
    const companies = await callClaude(KEY, [
      { type: "url", url: HUBSPOT_MCP, name: "hubspot" }
    ], `
Search HubSpot companies where:
- provider_segment_pre_launch = "Enterprise"
- lifecyclestage = "evangelist"

Return ALL matches (up to 200). For each company extract:
hs_object_id, name, state, city, moxie_onboarding_status, onboarding_status,
kickoff_date, initial_target_launch_date, updated_target_launch_date,
days_in_onboarding, onboarding_manager.

Then for each company, look up associated deals and pull monthly_medspa_revenue.
Merge revenue into the company record as monthly_revenue.

Return ONLY a raw JSON array, no markdown, no explanation.
`);

    const companyArr = extractJSON(companies) || [];

    // ── STEP 2: Pull recent Slack messages and categorize per account ──
    let notes = {};
    if (SLACK_MCP) {
      const accountKeys = companyArr
        .map(c => (c.name || "").toLowerCase().replace(/-\s*\d+$/, "").trim().split(" ")[0])
        .filter(Boolean);

      const slackResp = await callClaude(KEY, [
        { type: "url", url: SLACK_MCP, name: "slack" }
      ], `
Search Slack channels (#enterprise-onboarding, #onboarding-managers, or any channel
matching pattern "*onboarding*") for messages from the past 14 days mentioning
any of these enterprise accounts: ${accountKeys.join(", ")}.

For each match, classify the message as one of:
- "blocker"  : something is preventing forward progress (legal, missing data, vendor delay)
- "risk"     : a concern or potential issue (timeline slip, customer hesitation, scope creep)
- "update"   : positive or neutral progress update (kickoff complete, milestone hit)

Return ONLY a JSON object keyed by account name (lowercase, first word matches account):
{
  "rivkin": [
    {"type":"blocker","date":"Apr 29","text":"<concise 1-2 sentence summary>"},
    ...
  ],
  ...
}
Limit to the 5 most recent per account. No markdown.
`);

      notes = extractJSONObject(slackResp) || {};
    }

    return res.status(200).json({
      companies: companyArr,
      notes,
      synced_at: new Date().toISOString()
    });

  } catch (e) {
    console.error("Refresh failed:", e);
    return res.status(500).json({ error: e.message || "refresh failed" });
  }
}

// ── Helpers ──────────────────────────────────────────────────────────────────
async function callClaude(apiKey, mcpServers, prompt) {
  const r = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": apiKey,
      "anthropic-version": "2023-06-01",
      "anthropic-beta": "mcp-client-2025-04-04"
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-5",
      max_tokens: 4000,
      mcp_servers: mcpServers,
      messages: [{ role: "user", content: prompt }]
    })
  });
  if (!r.ok) throw new Error(`Anthropic API ${r.status}: ${await r.text()}`);
  const data = await r.json();
  return data.content.filter(b => b.type === "text").map(b => b.text).join("");
}

function extractJSON(text) {
  const m = (text || "").match(/\[[\s\S]*\]/);
  if (!m) return null;
  try { return JSON.parse(m[0]); } catch { return null; }
}

function extractJSONObject(text) {
  const m = (text || "").match(/\{[\s\S]*\}/);
  if (!m) return null;
  try { return JSON.parse(m[0]); } catch { return null; }
}
